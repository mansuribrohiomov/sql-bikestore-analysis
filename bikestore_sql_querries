drop procedure if exists sp_CalculateStoreKPI;
create procedure sp_CalculateStoreKPI
    @store_id int
as
begin

    -- validate store exists
    if not exists (select 1 from stores where store_id = @store_id)
    begin
        print 'store not found for id: ' + cast(@store_id as varchar)
        return
    end

    -- store info
    select
        store_id,
        store_name,
        city,
        state
    from stores
    where store_id = @store_id;

    -- revenue, orders, aov
    select
        count(distinct o.order_id) as total_orders,
        sum(oi.quantity * oi.list_price * (1 - oi.discount)) as total_revenue,
        sum(oi.quantity * oi.list_price * (1 - oi.discount))
            / count(distinct o.order_id) as avg_order_value,
        sum(oi.quantity) as total_units_sold
    from orders o
    join order_items oi on o.order_id = oi.order_id
    where o.store_id = @store_id;

    -- top 5 products by revenue for this store
    select top 5
        p.product_name,
        sum(oi.quantity) as units_sold,
        sum(oi.quantity * oi.list_price * (1 - oi.discount))as product_revenue
    from orders o
    join order_items oi on o.order_id   = oi.order_id
    join products p     on oi.product_id = p.product_id
    where o.store_id = @store_id
    group by p.product_id, p.product_name
    order by product_revenue desc;

    -- staff performance for this store
    select
        concat_ws(' ', sf.first_name,sf.last_name)  as staff_name,
        count(distinct o.order_id)as orders_handled,
        sum(oi.quantity * oi.list_price * (1 - oi.discount))as revenue_generated
    from staffs sf
    join orders o on sf.staff_id  = o.staff_id
    join order_items oi on o.order_id   = oi.order_id
    where o.store_id = @store_id
    group by sf.staff_id, sf.first_name, sf.last_name
    order by revenue_generated desc;

    -- inventory status for this store
    select
        p.product_name,
        st.quantity  as stock_quantity,
        case
            when st.quantity = 0    then 'out of stock'
            when st.quantity <= 5   then 'critical'
            when st.quantity <= 20  then 'low'
            else                         'sufficient'
        end  as stock_status
    from stocks st
    join products p on st.product_id = p.product_id
    where st.store_id = @store_id
    order by stock_quantity asc;

end;

-- how to run it
