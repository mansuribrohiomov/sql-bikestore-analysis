create procedure sp_GenerateRestockList
    @store_id int,
    @threshold int = 20    -- default low stock threshold
as
begin

    if not exists (select 1 from stores where store_id = @store_id)
    begin
        print 'store not found for id: ' + cast(@store_id as varchar)
        return
    end

    select
        s.store_name,
        p.product_id,
        p.product_name,
        b.brand_name,
        c.category_name,
        st.quantity as current_stock,
        case
            when st.quantity = 0 then 'out of stock'
            when st.quantity <= 5 then 'critical'
            when st.quantity <= 20 then 'low'
        end	 as stock_status,
        @threshold - st.quantity as units_needed
    from stocks st
    join stores s       on st.store_id      = s.store_id
    join products p     on st.product_id    = p.product_id
    join brands b       on p.brand_id       = b.brand_id
    join categories c   on p.category_id    = c.category_id
    where st.store_id   = @store_id
    and   st.quantity   < @threshold
    order by st.quantity asc;

end;

exec sp_GenerateRestockList @store_id = 1;
exec sp_GenerateRestockList @store_id = 1, @threshold = 10; 

drop procedure sp_CompareSalesYearOverYear
create procedure sp_CompareSalesYearOverYear
    @year1 int,
    @year2 int
as
begin

    select
        year(o.order_date)  as order_year,
        count(distinct o.order_id) as total_orders,
        sum(oi.quantity) as total_units_sold,
        sum(oi.quantity * oi.list_price * (1 - oi.discount)) as total_revenue,
        sum(oi.quantity * oi.list_price * (1 - oi.discount))
            / count(distinct o.order_id) as avg_order_value
    from orders o
    join order_items oi on o.order_id = oi.order_id
    where year(o.order_date) in (@year1, @year2)
    group by year(o.order_date)
    order by order_year;

    -- year over year difference
select
        @year1 as year1,
        @year2 as year2,
        sum(case when year(o.order_date) = @year2 then oi.quantity * oi.list_price * (1 - oi.discount) end) -
        sum(case when year(o.order_date) = @year1 then oi.quantity * oi.list_price * (1 - oi.discount) end)as revenue_difference,
        round(
            (sum(case when year(o.order_date) = @year2 then oi.quantity * oi.list_price * (1 - oi.discount) end) -
 sum(case when year(o.order_date) = @year1 then oi.quantity * oi.list_price * (1 - oi.discount) end)) /
 sum(case when year(o.order_date) = @year1 then oi.quantity * oi.list_price * (1 - oi.discount) end) * 100, 2)as revenue_growth_pct
from orders o
    join order_items oi on o.order_id = oi.order_id
    where year(o.order_date) in (@year1, @year2);

end;

exec sp_CompareSalesYearOverYear @year1 = 2016, @year2 = 2017;
exec sp_CompareSalesYearOverYear @year1 = 2017, @year2 = 2018;

create procedure sp_GetCustomerProfile
    @customer_id int
as
begin

    if not exists (select 1 from customers where customer_id = @customer_id)
    begin
        print 'customer not found for id: ' + cast(@customer_id as varchar)
        return
    end

    -- customer info
    select
        customer_id,
        concat_ws(' ',first_name,last_name) as customer_name,
        email,
        phone,
        city,
        state
    from customers
    where customer_id = @customer_id;

    -- overall spending summary
    select
        count(distinct o.order_id)                                      as total_orders,
        sum(oi.quantity)                                                 as total_units_bought,
        sum(oi.quantity * oi.list_price * (1 - oi.discount))            as total_spend,
        sum(oi.quantity * oi.list_price * (1 - oi.discount))
            / count(distinct o.order_id)as avg_order_value,
        min(o.order_date) as first_order_date,
        max(o.order_date) as last_order_date
    from orders o
    join order_items oi on o.order_id = oi.order_id
    where o.customer_id = @customer_id;

    -- top 5 most bought products
    select top 5
        p.product_name,
        c.category_name,
        sum(oi.quantity) as total_units_bought,
        sum(oi.quantity * oi.list_price * (1 - oi.discount)) as total_spent_on_product
    from orders o
    join order_items oi on o.order_id    = oi.order_id
    join products p     on oi.product_id = p.product_id
    join categories c   on p.category_id = c.category_id
    where o.customer_id = @customer_id
    group by p.product_id, p.product_name, c.category_name
    order by total_units_bought desc;

end;

